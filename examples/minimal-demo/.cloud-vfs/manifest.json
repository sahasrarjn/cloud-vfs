{
  "version": 3,
  "updated": "2026-05-29",
  "architecture": "minimal-demo — single local_archive",
  "local_archive": {
    "provider": "aws",
    "role": "Demo bucket (override in config.env)",
    "bucket": "your-test-bucket",
    "region": "us-east-1",
    "commands": {
      "offload": "cloud-vfs offload <path>",
      "fetch": "cloud-vfs ensure <path>"
    }
  },
  "entries": [
    {
      "id": "sample-tree",
      "local": "data/sample",
      "blob_prefix": "data/sample/",
      "archive": "local_archive",
      "status": "offload-candidate"
    }
  ]
}
