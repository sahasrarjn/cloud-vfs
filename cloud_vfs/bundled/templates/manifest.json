{
  "version": 2,
  "updated": "YYYY-MM-DD",
  "architecture": "Optional dual-blob — local archive and remote staging are independent (not synced)",
  "local_archive": {
    "role": "Long-term storage near the developer machine",
    "account": "YOUR_LOCAL_ACCOUNT",
    "container": "data",
    "region": "YOUR_LOCAL_REGION",
    "resource_group": "YOUR_LOCAL_RG",
    "base_url": "https://YOUR_LOCAL_ACCOUNT.blob.core.windows.net/data",
    "commands": {
      "offload": "cloud-vfs offload <path>",
      "fetch": "cloud-vfs ensure <path>"
    }
  },
  "remote_staging": {
    "role": "Optional second account near cloud compute (same or different region)",
    "account": "YOUR_REMOTE_ACCOUNT",
    "container": "data",
    "region": "YOUR_REMOTE_REGION",
    "resource_group": "YOUR_REMOTE_RG",
    "base_url": "https://YOUR_REMOTE_ACCOUNT.blob.core.windows.net/data",
    "commands": {
      "offload": "cloud-vfs offload --archive remote_staging <path>",
      "fetch": "cloud-vfs ensure <path>"
    }
  },
  "lifecycle": "ensure when needed → work locally → offload --dry-run → offload chosen paths",
  "entries": [
    {
      "id": "example-dataset",
      "local": "data/my_dataset",
      "blob_prefix": "data/my_dataset/",
      "archive": "local_archive",
      "status": "offload-candidate",
      "notes": "Example path — edit or remove"
    },
    {
      "id": "example-file",
      "local": "artifacts/model.bin",
      "blob": "artifacts/model.bin",
      "archive": "local_archive",
      "status": "synced"
    }
  ]
}
