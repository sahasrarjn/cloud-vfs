{
  "version": 3,
  "updated": "YYYY-MM-DD",
  "architecture": "Optional dual archive — independent backends (azure and/or aws)",
  "local_archive": {
    "provider": "azure",
    "role": "Long-term storage near the developer machine",
    "account": "YOUR_AZURE_ACCOUNT",
    "container": "data",
    "bucket": "your-s3-bucket-if-aws",
    "region": "YOUR_REGION",
    "base_url": "https://YOUR_AZURE_ACCOUNT.blob.core.windows.net/data",
    "commands": {
      "offload": "cloud-vfs offload <path>",
      "fetch": "cloud-vfs ensure <path>"
    }
  },
  "remote_staging": {
    "provider": "azure",
    "role": "Optional second archive (any provider, any region)",
    "account": "YOUR_REMOTE_AZURE_ACCOUNT",
    "container": "data",
    "bucket": "your-remote-s3-bucket-if-aws",
    "region": "YOUR_REMOTE_REGION",
    "base_url": "https://YOUR_REMOTE_AZURE_ACCOUNT.blob.core.windows.net/data",
    "commands": {
      "offload": "cloud-vfs offload --archive remote_staging <path>",
      "fetch": "cloud-vfs ensure <path>"
    }
  },
  "lifecycle": "ensure when needed → work locally → offload --dry-run → offload chosen paths",
  "entries": [
    {
      "id": "example-dataset",
      "local": "data/my_dataset",
      "blob_prefix": "data/my_dataset/",
      "archive": "local_archive",
      "status": "offload-candidate"
    },
    {
      "id": "example-aws-dataset",
      "local": "data/aws_only",
      "blob_prefix": "data/aws_only/",
      "archive": "local_archive",
      "provider": "aws",
      "status": "synced"
    }
  ]
}
