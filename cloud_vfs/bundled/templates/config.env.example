# Copy to runpod/config.env (or run infra/setup-blob-storage.sh)

# --- Local archive (Mac offload / manifest) ------------------------------------
AZ_LOCAL_RG="your-rg-local"
AZ_LOCAL_LOC="centralindia"
AZ_LOCAL_STORAGE_ACCOUNT="yourlocalaccount"
AZ_LOCAL_CONTAINER="esp-cl-data"

# --- Cloud staging (GPU/CPU experiment sync) ---------------------------------
AZ_RUNPOD_RG="your-rg-runpod"
AZ_RUNPOD_LOC="westeurope"
AZ_RUNPOD_STORAGE_ACCOUNT="yourrunpodaccount"
AZ_RUNPOD_CONTAINER="esp-cl-data"

AZ_BLOB_DATA_PREFIX="data"
AZ_BLOB_CODE_PREFIX="code"
AZ_BLOB_CHECKPOINTS_PREFIX="checkpoints"

# --- RunPod (optional) -------------------------------------------------------
RUNPOD_POD_NAME="my-pod"
RUNPOD_GPU_ID="NVIDIA GeForce RTX 3090"
RUNPOD_DC="EU-CZ-1"
RUNPOD_TEMPLATE_ID="runpod-torch-v220"
RUNPOD_CLOUD_TYPE="SECURE"
RUNPOD_CONTAINER_DISK_GB=20
RUNPOD_VOLUME_GB=50
RUNPOD_VOLUME_MOUNT="/workspace"

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
