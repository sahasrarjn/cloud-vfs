# Copy to .cloud-vfs/config.env

# --- Provider per archive: azure | aws ----------------------------------------
LOCAL_PROVIDER="azure"
REMOTE_PROVIDER="azure"

# --- Azure: local archive -----------------------------------------------------
AZ_LOCAL_RG="your-resource-group"
AZ_LOCAL_LOC="eastus"
AZ_LOCAL_STORAGE_ACCOUNT="yourlocalstorageaccount"
AZ_LOCAL_CONTAINER="data"

# --- Azure: remote staging (optional second account) --------------------------
AZ_REMOTE_RG="your-staging-resource-group"
AZ_REMOTE_LOC="westeurope"
AZ_REMOTE_STORAGE_ACCOUNT="yourremotestorageaccount"
AZ_REMOTE_CONTAINER="data"

# --- AWS: local archive (when LOCAL_PROVIDER=aws) -----------------------------
AWS_LOCAL_BUCKET="your-bucket"
AWS_LOCAL_REGION="us-east-1"
# AWS_LOCAL_PROFILE="default"

# --- AWS: remote staging (when REMOTE_PROVIDER=aws) ---------------------------
AWS_REMOTE_BUCKET="your-staging-bucket"
AWS_REMOTE_REGION="us-east-1"

AZ_BLOB_DATA_PREFIX="data"
AZ_BLOB_CODE_PREFIX="code"
AZ_BLOB_CHECKPOINTS_PREFIX="checkpoints"
